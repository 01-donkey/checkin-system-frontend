---
import '../style/global.css';

---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>系統後台登入</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  </head>
  <body class="bg-gray-100 min-h-screen p-4 flex flex-col items-center justify-center ">
    
    <div id="login-section" class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-sm text-center mx-auto mt-10">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">🔒 管理員登入</h1>
      <input type="password" id="admin-pwd" placeholder="請輸入管理員密碼" class="w-full px-4 py-3 rounded-lg border focus:ring-2 focus:ring-blue-500 outline-none text-center mb-4">
      <button id="login-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors">登入系統</button>
      <p id="login-error" class="text-red-500 text-sm mt-3 hidden">密碼錯誤，請重試。</p>
    </div>

    <div id="dashboard-section" class="w-full max-w-6xl hidden flex-col gap-6 mx-auto my-10 px-4">
      
      <div class="bg-white rounded-2xl shadow p-6 flex flex-wrap items-end gap-4 justify-between transition-all" id="settings-card">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-lg font-bold text-gray-800">⚙️ 系統開放時間控制</h2>
            <span id="current-status-badge" class="px-2 py-1 rounded-md text-xs font-bold bg-gray-200 text-gray-500 transition-colors">檢查中...</span>
          </div>
          <div class="flex items-center gap-2 text-gray-600 text-sm">
            <span>開放：</span>
            <input type="text" id="open-time" readonly class="time-picker border border-gray-300 rounded px-2 py-1 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 w-24 text-center" placeholder="選擇時間">

            <span>～ 關閉：</span>
            <input type="text" id="close-time" readonly class="time-picker border border-gray-300 rounded px-2 py-1 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 w-24 text-center" placeholder="選擇時間">
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <button id="open-display-btn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg font-bold shadow-md transition-all">
            🖥️ 啟動現場簽到螢幕
          </button>
          <button id="save-time-btn" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg font-medium transition-all duration-300">
            儲存時間設定
          </button>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <div class="flex flex-wrap justify-between items-center mb-6 gap-4">
          <div class="flex items-center gap-4">
            <h2 class="text-xl font-bold text-gray-800">📋 現場人員動態</h2>
            <div class="flex gap-2">
              <div class="bg-emerald-50 border border-emerald-100 text-emerald-700 px-3 py-1 rounded-lg text-sm font-bold shadow-sm">
                目前在場：<span id="stat-present" class="text-lg">0</span> 人
              </div>
              <div class="bg-gray-50 border border-gray-200 text-gray-600 px-3 py-1 rounded-lg text-sm font-bold shadow-sm">
                今日已簽退：<span id="stat-left" class="text-lg">0</span> 人
              </div>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 items-center">
            <div class="flex items-center gap-2 bg-yellow-50 border border-yellow-200 rounded px-3 py-1.5 shadow-sm">
              <span class="text-sm text-yellow-800 font-bold">📍 場地切換:</span>
              <select id="location-filter" class="border-none text-sm text-gray-800 outline-none bg-transparent cursor-pointer font-medium">
                <option value="ALL">顯示全部場地</option>
              </select>
            </div>

            <div class="flex items-center gap-2 bg-white border border-gray-200 rounded px-2 py-1.5 shadow-sm">
              <span class="text-xs">🔍</span>
              <input type="text" id="record-search" placeholder="搜尋姓名/組別" class="border-none text-sm text-gray-700 outline-none bg-transparent w-28 placeholder-gray-400">
            </div>

            <div class="flex items-center gap-2 bg-white border border-gray-200 rounded px-2 py-1.5 shadow-sm">
              <span class="text-xs text-gray-500 font-medium">匯出範圍:</span>
              <select id="export-range" class="border-none text-sm text-gray-700 outline-none bg-transparent cursor-pointer font-bold">
                <option value="ALL">全部資料</option>
                <option value="TODAY">今天</option>
                <option value="LAST_3_DAYS">近 3 天</option>
                <option value="LAST_7_DAYS">近 7 天</option>
                <option value="CUSTOM">自訂區間...</option>
              </select>

              <div id="custom-date-wrap" class="hidden items-center gap-1">
                <span class="text-gray-300">|</span>
                <input type="date" id="export-start" class="border-none text-sm text-gray-700 outline-none bg-transparent cursor-pointer">
                <span class="text-gray-400">~</span>
                <input type="date" id="export-end" class="border-none text-sm text-gray-700 outline-none bg-transparent cursor-pointer">
              </div>
            </div>
            
            <button id="export-btn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded transition-colors text-sm font-medium shadow-sm">📊 下載報表</button>
            <button id="refresh-btn" class="text-blue-600 hover:bg-blue-50 px-3 py-1.5 rounded transition-colors text-sm font-medium border border-blue-200">🔄 重新整理</button>
          </div>
        </div>

        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-center border-collapse min-w-[800px]">
            <thead>
              <tr class="bg-gray-100 text-gray-600 text-sm border-b border-gray-200">
                <th class="p-3 whitespace-nowrap">日期</th>
                <th class="p-3 whitespace-nowrap">組別</th>
                <th class="p-3 whitespace-nowrap">副組別</th>
                <th class="p-3 whitespace-nowrap">姓名</th>
                <th class="p-3 whitespace-nowrap">場地</th>
                <th class="p-3 whitespace-nowrap text-emerald-600">🟢 簽到時間</th>
                <th class="p-3 whitespace-nowrap text-rose-600">🔴 簽退時間</th>
                <th class="p-3">便當選擇</th>
                <th class="p-3">特殊狀況</th>
              </tr>
            </thead>
            <tbody id="record-table-body" class="text-sm divide-y divide-gray-100"></tbody>
          </table>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border-l-4 border-purple-500">
        <h2 class="text-lg font-bold text-gray-800 mb-2">📅 每日排班表 (白名單門禁)</h2>
        <p class="text-xs text-gray-500 mb-4">請從 Excel 複製「姓名」與「生日四碼」（中間空格或逗號皆可），直接貼入下方。一旦上傳，當天只有名單上的人能打卡！</p>
        
        <div class="flex flex-col md:flex-row gap-4 items-start">
          <textarea id="roster-input" rows="4" class="w-full md:w-2/3 p-3 text-sm border border-gray-300 rounded-lg outline-none focus:ring-2 focus:ring-purple-500 bg-gray-50" placeholder="範例：&#10;王大明 1234&#10;李小華 5678"></textarea>
          
          <div class="w-full md:w-1/3 flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <span class="text-sm font-bold text-gray-700">生效日期:</span>
              <input type="date" id="roster-date" class="border border-gray-300 rounded px-2 py-1 outline-none text-sm w-full">
            </div>
            <button id="upload-roster-btn" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 rounded-lg transition-colors">🚀 上傳並鎖定當日權限</button>
            <button id="clear-roster-btn" class="w-full bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm py-1 rounded-lg transition-colors mt-1">🗑️ 清空當日班表 (解除鎖定)</button>
            <button id="confirm-roster-btn"
              class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-4 py-2 rounded-lg transition-colors text-sm">
              ✅ 確認存入資料庫
            </button>
          </div>
        </div>

        <div class="flex flex-wrap justify-between items-center mb-3 gap-2 mt-4">
            <h3 class="font-bold text-purple-800 text-sm">📋 班表與出勤狀態 (<span id="roster-date-display">今天</span>)</h3>
            
            <div class="flex gap-2 items-center">
              <div class="flex items-center gap-1 bg-white border border-purple-200 rounded px-2 py-1 shadow-sm">
                <span class="text-xs">🔍</span>
                <input type="text" id="roster-search" placeholder="搜尋姓名/四碼" class="border-none text-xs outline-none bg-transparent w-24 placeholder-gray-400">
              </div>
              <button id="refresh-roster-btn" class="text-xs bg-purple-100 hover:bg-purple-200 text-purple-700 px-3 py-1 rounded-md font-bold transition-colors">🔄 更新名單</button>
            </div>
        </div>
          
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-gray-50 p-3 rounded-lg border border-gray-200">
            <h4 class="text-xs font-bold text-gray-600 mb-2">✅ 當日排班名單 (<span id="roster-count">0</span>人)</h4>
            <ul id="roster-list-ul" class="text-sm text-gray-700 h-32 overflow-y-auto space-y-1.5 list-inside list-disc">
              <li class="text-gray-400 italic">載入中...</li>
            </ul>
          </div>
          <div class="bg-red-50 p-3 rounded-lg border border-red-200">
            <h4 class="text-xs font-bold text-red-600 mb-2">⚠️ 尚未簽到 (<span id="absent-count">0</span>人)</h4>
            <ul id="absent-list-ul" class="text-sm text-gray-700 h-32 overflow-y-auto space-y-1.5 list-inside list-disc">
              <li class="text-gray-400 italic">載入中...</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-lg font-bold text-gray-800 mb-1">📊 員工出缺席率匯出</h2>
        <p class="text-xs text-gray-400 mb-4">
          需先上傳班表並按「確認存入資料庫」後，該日排班才會納入統計。
        </p>

        <div class="flex flex-wrap items-end gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">起始日期</label>
            <input type="date" id="attendance-start"
              class="border border-gray-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-emerald-400">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">結束日期</label>
            <input type="date" id="attendance-end"
              class="border border-gray-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-emerald-400">
          </div>
          <button id="export-attendance-btn"
            class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-5 py-2 rounded-lg transition-colors text-sm shadow-sm">
            📥 下載出缺席率 CSV
          </button>
        </div>

        <p class="text-xs text-gray-400 mt-3">
          📄 CSV 包含兩段：逐日出缺席明細 ＋ 個人出席率統計表
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border-l-4 border-blue-500 mb-6">
        <h2 class="text-lg font-bold text-gray-800 mb-2">⏱️ 產生時效性打卡條碼 (群組/機動專用)</h2>
        <p class="text-xs text-gray-500 mb-4">適用於發布在 LINE 群組或機動支援。此條碼在您設定的時間內不會變更，可讓多人重複掃描使用。</p>
        
        <div class="flex flex-col md:flex-row gap-6">
          <div class="w-full md:w-1/2 space-y-4">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">1. 選擇場地</label>
              <select id="temp-qr-location" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"></select>
            </div>
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">2. 打卡類型</label>
              <select id="temp-qr-action" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50">
                <option value="IN">🟢 上班簽到</option>
                <option value="OUT">🔴 下班簽退</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">3. 有效時間</label>
              <select id="temp-qr-duration" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50">
                <option value="600000">10 分鐘</option>
                <option value="1800000">30 分鐘</option>
                <option value="3600000">1 小時</option>
                <option value="43200000">12 小時 (整天不換)</option>
              </select>
            </div>
            <button id="generate-temp-qr-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition-colors shadow-sm">⚡ 立即生成專屬條碼</button>
          </div>
          
          <div class="w-full md:w-1/2 flex flex-col items-center justify-center bg-gray-50 rounded-xl border-2 border-dashed border-gray-300 p-4 min-h-[250px]">
            <canvas id="temp-qr-canvas" class="hidden rounded-lg shadow-sm mb-3 border-4 border-white"></canvas>
            <p id="temp-qr-countdown" class="text-sm font-bold text-red-500 hidden"></p>
            <div id="temp-qr-link-box" class="w-full hidden mt-3">
              <label class="text-xs text-gray-500 font-bold mb-1 block text-center">👇 亦可直接複製此連結發送至群組</label>
              <input type="text" id="temp-qr-link" class="w-full text-xs text-gray-500 p-2 border border-gray-200 rounded outline-none bg-white text-center cursor-copy" readonly>
            </div>
            <p id="temp-qr-placeholder" class="text-gray-400 text-sm font-medium">請選擇條件並點擊生成</p>
          </div>
        </div>
      </div>

      <!-- 最外圈... -->
    </div>

      
    <script>

      // ✅ 修正寫法（讓 Vite 自動解析副檔名）
      import { ApiClient } from '../scripts/admin/ApiClient';
      import { SystemManager } from '../scripts/admin/SystemManager';
      import { RecordManager } from '../scripts/admin/RecordManager';
      import { RosterManager } from '../scripts/admin/RosterManager';
      import { QRManager } from '../scripts/admin/QRManager';

      // 1. 初始化 API 客戶端
      const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
      const apiClient = new ApiClient(API_URL);
      const savedToken = sessionStorage.getItem('admin_jwt');
      if (savedToken) {
        apiClient.setToken(savedToken);
        // 可以選擇自動觸發 onLoginSuccess，讓已登入的管理員不用重新輸入密碼
      }
      // 2. 初始化各個功能模組
      const recordManager = new RecordManager(apiClient);
      const rosterManager = new RosterManager(apiClient);
      const qrManager = new QRManager(apiClient);

      // 3. 初始化系統管理器，並設定登入成功後的回呼函數 (Callback)
      const systemManager = new SystemManager(apiClient, () => {
        // 當登入成功時，觸發其他模組抓取初始資料
        recordManager.fetchRecords();
        rosterManager.loadRosterList();
        qrManager.loadLocations();
      });

    </script>
  </body>
</html>