---
import '../style/global.css';
// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.

//npm run dev -- --host
---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SNA/COSTA 現場打卡系統</title>
  </head>
  <body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">
<main class="bg-white rounded-2xl shadow-lg w-full max-w-sm p-6 text-center">
      <h1 class="text-2xl font-bold text-gray-800 mb-2">現場人員打卡</h1>
      <p class="text-gray-500 mb-6 text-sm">請輸入您的生日四碼並確認打卡類型</p>

      <!-- 表單輸入區塊開始 -->
      <div class="space-y-4 mb-6 text-left">
        
        <!-- 1. 姓名 -->
        <div id="name-container">
          <label class="block text-sm font-semibold text-gray-700 mb-1">您的姓名</label>
          <input 
            type="text" 
            id="name-input" 
            placeholder="例如：王小明" 
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none text-lg"
          >
        </div>

        <!-- 2. 手機尾碼 (原生日四碼) -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">生日四碼</label>
          <input 
            type="tel" 
            id="phone-input" 
            maxlength="4" 
            placeholder="例如：0909" 
            pattern="\d{4}"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-lg tracking-widest"
          >
        </div>

        <!-- 3. 所屬組別 -->
        <div id="group-container" class="hidden">
          <label class="block text-sm font-semibold text-gray-700 mb-1">所屬組別</label>
          <select id="group-select" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none text-lg bg-white">
            <option value="" disabled selected>請選擇組別</option>
            <option value="1樓指引">1樓指引</option>
            <option value="2樓指引">2樓指引</option>
            <option value="行李房">行李房</option>
            <option value="X光機">X光機</option>
            <option value="一般報到櫃檯">一般報到櫃檯</option>
            <option value="一般行李託運櫃檯">一般行李託運櫃檯</option>
            <option value="套房報到櫃檯">套房報到櫃檯</option>
            <option value="套房行李託運櫃檯">套房行李託運櫃檯</option>
            <option value="移民署">移民署</option>
          </select>
        </div>
        <!-- 【新增】副組別 (預設隱藏) -->
        <div id="sub-group-container" class="hidden">
            <label class="block text-sm font-semibold text-gray-700 mb-1">副組別 (選填)</label>
            <select id="sub-group-select" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none text-lg bg-white">
              <option value="">無副組別</option>
            <option value="1樓指引">1樓指引</option>
            <option value="2樓指引">2樓指引</option>
            <option value="行李房">行李房</option>
            <option value="X光機">X光機</option>
            <option value="一般報到櫃檯">一般報到櫃檯</option>
            <option value="一般行李託運櫃檯">一般行李託運櫃檯</option>
            <option value="套房報到櫃檯">套房報到櫃檯</option>
            <option value="套房行李託運櫃檯">套房行李託運櫃檯</option>
            <option value="移民署">移民署</option>
            </select>
          </div>

          <div id="special-status-container" class="hidden">
            <label class="block text-sm font-semibold text-gray-700 mb-1">特殊狀況紀錄 (選填)</label>
            <textarea 
              id="special-status-input" 
              rows="2"
              maxlength="500"
              placeholder="若有器材損壞、人員受傷等狀況請註記" 
              class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none text-lg"
            ></textarea>
          </div>

        <!-- 【新增】今日便當調查 (預設隱藏) -->
        <div id="bento-container" class="hidden">
          <label class="block text-sm font-semibold text-gray-700 mb-1">今日便當調查</label>
          <select id="bento-select" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none text-lg bg-white">
            <option value="" disabled selected>請選擇便當種類</option>
            <option value="葷食便當"> 葷食</option>
            <option value="素食便當"> 素食</option>
          </select>
        </div>

        <!-- 4. 打卡類型 (唯讀顯示區) -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">打卡類型</label>
          <div id="action-display" class="w-full px-4 py-3 rounded-lg text-lg font-bold text-center border">
            讀取條碼中...
          </div>
        </div>

      </div> 
      <!-- 表單輸入區塊結束 (這個 div 正確對齊 space-y-4) -->

      <!-- 按鈕與狀態列 (現在它們安全地待在 main 白框裡面了) -->
      <button 
        id="checkin-btn"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 rounded-xl shadow-md transition-colors text-lg flex items-center justify-center gap-2"
      >
        <span>📍 點擊獲取位置並送出</span>
      </button>

      <div id="status-box" class="mt-6 p-4 rounded-lg bg-gray-50 hidden text-left text-sm">
        <p id="status-text" class="text-gray-700 font-medium pb-2 border-b"></p>
        <div class="mt-2 text-gray-400 space-y-1 text-xs">
          <p>Lat: <span id="lat-val">--</span> | Lng: <span id="lng-val">--</span></p>
        </div>
      </div>

    </main>

<script>
    // 🌟【升級】定義動態 API 網址
      const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
      const btn = document.getElementById('checkin-btn');
      const nameInput = document.getElementById('name-input');
      const phoneInput = document.getElementById('phone-input');
      const statusBox = document.getElementById('status-box');
      const statusText = document.getElementById('status-text');
      const latVal = document.getElementById('lat-val');
      const lngVal = document.getElementById('lng-val');
      
      const groupContainer = document.getElementById('group-container');
      const groupSelect = document.getElementById('group-select');
      
      const bentoContainer = document.getElementById('bento-container');
      const bentoSelect = document.getElementById('bento-select');
      
      const nameContainer = document.getElementById('name-container');
      const actionDisplay = document.getElementById('action-display');

      // 宣告新變數副組別，特殊狀況紀錄相關元素
      const subGroupContainer = document.getElementById('sub-group-container');
      const subGroupSelect = document.getElementById('sub-group-select');
      const specialStatusContainer = document.getElementById('special-status-container');
      const specialStatusInput = document.getElementById('special-status-input');

      const urlParams = new URLSearchParams(window.location.search);
      const urlLoc = urlParams.get('loc');
      const urlToken = urlParams.get('token');
      const urlAction = urlParams.get('action'); 

      if (urlAction === 'IN') {
        actionDisplay.textContent = '🟢 上班簽到 (Check In)';
        actionDisplay.className = 'w-full px-4 py-3 rounded-lg text-lg font-bold text-center border border-emerald-300 bg-emerald-50 text-emerald-700';
        nameContainer.classList.remove('hidden'); 
        groupContainer.classList.add('hidden');   
        bentoContainer.classList.remove('hidden'); 
      } 
      else if (urlAction === 'OUT') {
        actionDisplay.textContent = '🔴 下班簽退 (Check Out)';
        actionDisplay.className = 'w-full px-4 py-3 rounded-lg text-lg font-bold text-center border border-rose-300 bg-rose-50 text-rose-700';
        nameContainer.classList.add('hidden');       
        groupContainer.classList.remove('hidden');   
        bentoContainer.classList.add('hidden');    
        subGroupContainer.classList.remove('hidden'); // 顯示副組別
        specialStatusContainer.classList.remove('hidden'); // 顯示特殊狀況
      } 
      else {
        actionDisplay.textContent = '⚠️ 條碼無效';
        actionDisplay.className = 'w-full px-4 py-3 rounded-lg text-lg font-bold text-center border border-red-300 bg-red-50 text-red-700';
        btn.disabled = true;
        btn.classList.add('opacity-50', 'cursor-not-allowed');
      }

      // 🌟【架構升級】：改用 async/await 統一風格，程式碼更乾淨好維護
      async function sendCheckinRequest(lat, lng) {
        const nameVal = nameInput.value.trim();
        const phoneVal = phoneInput.value.trim();
        const groupVal = urlAction === 'OUT' ? groupSelect.value : '';
        const bentoVal = urlAction === 'IN' ? bentoSelect.value : ''; 
        const subGroupVal = urlAction === 'OUT' ? subGroupSelect.value : '';
        const specialStatusVal = urlAction === 'OUT' ? specialStatusInput.value.trim() : '';

        try {
          // 使用 await 等待伺服器回應
          const response = await fetch(`${API_URL}/api/checkin`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: nameVal,
              phone_last4: phoneVal,
              action: urlAction,
              location_id: parseInt(urlLoc),
              lat: lat,
              lng: lng,
              token: urlToken,
              group: groupVal,
              sub_group: subGroupVal,       // 傳送副組別
              special_status: specialStatusVal, // 傳送特殊狀況
              bento: bentoVal
            })
          });
          
          // 使用 await 解析 JSON 資料
          const data = await response.json();
          
          if (data.success) {
            showStatus(data.message, false);
            btn.innerHTML = '🎉 紀錄已完成';
          } else {
            showStatus(`❌ ${data.message}`, true);
            btn.disabled = false;
            btn.innerHTML = '📍 重新點擊送出';
          }
        } catch (error) {
          // 統一在這裡捕捉網路斷線或伺服器錯誤
          showStatus('❌ 伺服器連線失敗', true);
          btn.disabled = false;
          btn.innerHTML = '📍 重新點擊送出';
        }
      }

      btn.addEventListener('click', () => {
        if (!urlAction || (urlAction !== 'IN' && urlAction !== 'OUT')) {
          showStatus('❌ 錯誤：無效的打卡條碼，請重新掃描', true);
          return;
        }
        if (!urlLoc || !urlToken) {
          showStatus('❌ 錯誤：缺少打卡憑證。請確保您是掃描現場看板進入！', true);
          return;
        }
        if (phoneInput.value.trim().length !== 4 || isNaN(phoneInput.value.trim())) {
          showStatus('❌ 錯誤：請輸入正確的 4 碼數字', true);
          return;
        }
        if (urlAction === 'IN' && !nameInput.value.trim()) {
          showStatus('❌ 錯誤：上班簽到請務必輸入您的姓名', true);
          return;
        }
        if (urlAction === 'OUT' && !groupSelect.value) {
          showStatus('❌ 錯誤：請選擇您所屬的組別', true);
          return;
        }
        if (urlAction === 'IN' && !bentoSelect.value) {
          showStatus('❌ 錯誤：請選擇您的便當種類', true);
          return;
        }
        // 🌟 【新增】：在這裡進行前端的安全驗證
        const specialStatusVal = specialStatusInput.value.trim();
        if (urlAction === 'OUT' && specialStatusVal.length > 500) {
          showStatus('❌ 錯誤：特殊狀況描述不能超過 500 字', true);
          return;
        }

        btn.disabled = true;
        btn.innerHTML = '🔄 處理中...';
        showStatus('正在獲取 GPS 與驗證身分...', false);

        navigator.geolocation.getCurrentPosition(
          (position) => {
            const lat = position.coords.latitude;
            const lng = position.coords.longitude;
            latVal.textContent = lat.toFixed(4);
            lngVal.textContent = lng.toFixed(4);
            
            sendCheckinRequest(lat, lng);
          },
          (error) => {
            showStatus('❌ 定位失敗：請至設定開啟位置權限。', true);
            btn.disabled = false;
            btn.innerHTML = '📍 重新點擊送出';
          },
          { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
        );
      });

      function showStatus(message, isError) {
        statusBox.classList.remove('hidden');
        statusText.innerText = message;
        statusText.className = isError ? 'text-red-600 font-bold pb-2 border-b' : 'text-green-700 font-bold pb-2 border-b text-lg';
      }
    </script>
  </body>
</html>